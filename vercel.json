{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/docs/:path*",
      "destination": "/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/docs/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
